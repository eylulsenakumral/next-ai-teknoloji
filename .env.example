# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextai

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# BizimHesap API
BIZIMHESAP_API_KEY=0B413362518942E88F3A1039658A0C2B
BIZIMHESAP_TOKEN=

# Redis (Docker Compose maps container 6379 → host 6380)
REDIS_URL=redis://localhost:6380

# AI (WhatsApp bot)
OPENAI_API_KEY=

# LLM / WhatsApp AI worker
WHATSAPP_AI_BASE_URL=http://your-llm-host/v1
WHATSAPP_AI_API_KEY=your-whatsapp-ai-api-key
WHATSAPP_AI_MODEL=your-model-name

# Z.AI (GLM — category matcher script)
Z_AI_API_KEY=your-z-ai-api-key
Z_AI_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
Z_AI_MODEL=glm-5-turbo

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nextai-assets

# Scraper — B2BDepo
SCRAPER_B2BDEPO_BAYI_KODU=your_bayi_kodu
SCRAPER_B2BDEPO_KULLANICI=your_username
SCRAPER_B2BDEPO_SIFRE=your_password
SCRAPER_B2BDEPO_GUVENLIK=your_security_answer

# Scraper — Okisan
SCRAPER_OKISAN_USER=your_username
SCRAPER_OKISAN_PASS=your_password

# Firebase (client-side — NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
